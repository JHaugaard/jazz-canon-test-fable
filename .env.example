# Cloudflare Pages deployment credentials for A Jazz Canon.
#
# Copy this file to ".env" (that copy is gitignored and will NEVER be pushed):
#     cp .env.example .env
# then fill in the two values below.
#
# CLOUDFLARE_API_TOKEN — a scoped API token. Create it here:
#     https://dash.cloudflare.com/profile/api-tokens
#   Create Custom Token, one permission:  Account · Cloudflare Pages · Edit
#
# CLOUDFLARE_ACCOUNT_ID — not secret. It's the long hex string in your
#   dashboard URL: dash.cloudflare.com/<THIS_IS_YOUR_ACCOUNT_ID>

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
